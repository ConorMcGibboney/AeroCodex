{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentToolSpec",
  "type": "object",
  "required": [
    "name",
    "codex_id",
    "title",
    "description",
    "input_schema",
    "output_schema",
    "error_schema",
    "evidence"
